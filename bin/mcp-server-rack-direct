#!/usr/bin/env ruby
# frozen_string_literal: true

# Run Puma with pure Rack app - no Sinatra, no rackup, no automatic middleware

require 'bundler/setup'
require 'dotenv'

# Load .env file BEFORE any application code to ensure ENV is set
# Use absolute path to ensure it works regardless of how script is invoked
Dotenv.load(File.expand_path('../.env', __dir__))

require 'puma'
require 'mcp'
require_relative '../lib/hyperon/wiki/mcp'
require_relative '../lib/hyperon/wiki/mcp/rack_app'

# Load all tool classes
Dir[File.join(__dir__, '../lib/hyperon/wiki/mcp/server/tools/**/*.rb')].sort.each { |f| require f }

# Get configuration from environment
PORT = ENV.fetch("MCP_SERVER_PORT", "3002").to_i
HOST = ENV.fetch("MCP_SERVER_HOST", "127.0.0.1")
working_directory = ENV["MAGI_WORKING_DIR"] || "/home/ubuntu"

# Initialize tools
magi_tools = Hyperon::Wiki::Mcp::Tools.new

# Create server context
server_context = {
  magi_tools: magi_tools,
  working_directory: working_directory
}

# Create MCP server
mcp_server = ::MCP::Server.new(
  name: "hyperon-wiki",
  version: Hyperon::Wiki::Mcp::VERSION,
  tools: [
    # ChatGPT connector-compatible tools (must be first for OpenAI compatibility)
    Hyperon::Wiki::Mcp::Server::Tools::Search,
    Hyperon::Wiki::Mcp::Server::Tools::Fetch,
    Hyperon::Wiki::Mcp::Server::Tools::GetSiteContext,

    # Core card operations
    Hyperon::Wiki::Mcp::Server::Tools::GetCard,
    Hyperon::Wiki::Mcp::Server::Tools::SearchCards,
    Hyperon::Wiki::Mcp::Server::Tools::CreateCard,
    Hyperon::Wiki::Mcp::Server::Tools::UpdateCard,
    Hyperon::Wiki::Mcp::Server::Tools::DeleteCard,
    Hyperon::Wiki::Mcp::Server::Tools::RenameCard,
    Hyperon::Wiki::Mcp::Server::Tools::ListChildren,

    # Tag operations
    Hyperon::Wiki::Mcp::Server::Tools::GetTags,
    Hyperon::Wiki::Mcp::Server::Tools::SearchByTags,
    Hyperon::Wiki::Mcp::Server::Tools::SuggestTags,

    # Relationships
    Hyperon::Wiki::Mcp::Server::Tools::GetRelationships,

    # Types and rendering
    Hyperon::Wiki::Mcp::Server::Tools::GetTypes,
    Hyperon::Wiki::Mcp::Server::Tools::RenderContent,

    # Admin operations
    Hyperon::Wiki::Mcp::Server::Tools::AdminBackup,

    # Card history and restore
    Hyperon::Wiki::Mcp::Server::Tools::GetCardHistory,
    Hyperon::Wiki::Mcp::Server::Tools::GetRevision,
    Hyperon::Wiki::Mcp::Server::Tools::RestoreCard,
    Hyperon::Wiki::Mcp::Server::Tools::ListTrash,

    # Weekly summaries
    Hyperon::Wiki::Mcp::Server::Tools::CreateWeeklySummary,

    # Health check
    Hyperon::Wiki::Mcp::Server::Tools::HealthCheck,

    # Phase 3: Advanced operations
    Hyperon::Wiki::Mcp::Server::Tools::BatchCards,
    Hyperon::Wiki::Mcp::Server::Tools::RunQuery,
    Hyperon::Wiki::Mcp::Server::Tools::SpoilerScan,

    # Auto-linking
    Hyperon::Wiki::Mcp::Server::Tools::AutoLink
  ],
  server_context: server_context
)

# Set MCP server instance on the app class
Hyperon::Wiki::Mcp::RackApp.mcp_server_instance = mcp_server

# Initialize OAuth components
begin
  require_relative '../lib/hyperon/wiki/mcp/oauth/token_issuer'
  require_relative '../lib/hyperon/wiki/mcp/oauth/credential_store'
  require_relative '../lib/hyperon/wiki/mcp/oauth/client_cards'
  require_relative '../lib/hyperon/wiki/mcp/oauth/rate_limiter'
  require_relative '../lib/hyperon/wiki/mcp/oauth/pkce_verifier'
  require_relative '../lib/hyperon/wiki/mcp/oauth/login_page'

  token_issuer = Hyperon::Wiki::Mcp::OAuth::TokenIssuer.new
  credential_store = Hyperon::Wiki::Mcp::OAuth::CredentialStore.new
  client_cards = Hyperon::Wiki::Mcp::OAuth::ClientCards.new(
    tools: magi_tools,
    encryption_key: token_issuer.encryption_key
  )
  rate_limiter = Hyperon::Wiki::Mcp::OAuth::RateLimiter.new

  Hyperon::Wiki::Mcp::RackApp.token_issuer = token_issuer
  Hyperon::Wiki::Mcp::RackApp.credential_store = credential_store
  Hyperon::Wiki::Mcp::RackApp.client_cards = client_cards
  Hyperon::Wiki::Mcp::RackApp.rate_limiter = rate_limiter

  puts "OAuth 2.1 enabled (require_auth=#{ENV.fetch('OAUTH_REQUIRE_AUTH', 'false')})"
rescue StandardError => e
  puts "OAuth initialization skipped: #{e.message}"
end

# Create Rack app instance with security middleware
app = Hyperon::Wiki::Mcp::RackApp.new
app_with_security = Hyperon::Wiki::Mcp::HostAuthorization.new(app)

# Run Puma directly with pure Rack app
Puma::Server.new(app_with_security).tap do |server|
  server.add_tcp_listener HOST, PORT
  puts "Hyperon Wiki MCP Server v#{Hyperon::Wiki::Mcp::VERSION}"
  puts "Pure Rack Mode (No Sinatra, No Rackup, No Middleware)"
  puts "Listening on http://#{HOST}:#{PORT}"
  puts "Working directory: #{working_directory}"
  puts "Authenticated as: #{magi_tools.client.config.username || 'API Key'}"
  server.run.join
end
