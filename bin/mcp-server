#!/usr/bin/env ruby
# frozen_string_literal: true

# MCP Server executable for Hyperon Wiki
# This server implements the Model Context Protocol to enable
# Claude Desktop, Codex, and other MCP clients to interact with
# the Hyperon Wiki wiki.

require "bundler/setup"
require "mcp"

# Configure JSON Schema validator before loading tools
require_relative "../lib/hyperon/wiki/mcp/schema_config"

require_relative "../lib/hyperon/wiki/mcp"

# Load all MCP tool classes
# Core card operations
require_relative "../lib/hyperon/wiki/mcp/server/tools/get_card"
require_relative "../lib/hyperon/wiki/mcp/server/tools/search_cards"
require_relative "../lib/hyperon/wiki/mcp/server/tools/create_card"
require_relative "../lib/hyperon/wiki/mcp/server/tools/update_card"
require_relative "../lib/hyperon/wiki/mcp/server/tools/delete_card"
require_relative "../lib/hyperon/wiki/mcp/server/tools/rename_card"
require_relative "../lib/hyperon/wiki/mcp/server/tools/list_children"

# Tag operations
require_relative "../lib/hyperon/wiki/mcp/server/tools/get_tags"
require_relative "../lib/hyperon/wiki/mcp/server/tools/search_by_tags"
require_relative "../lib/hyperon/wiki/mcp/server/tools/suggest_tags"

# Relationships
require_relative "../lib/hyperon/wiki/mcp/server/tools/get_relationships"


# Types and rendering
require_relative "../lib/hyperon/wiki/mcp/server/tools/get_types"
require_relative "../lib/hyperon/wiki/mcp/server/tools/render_content"

# Admin operations
require_relative "../lib/hyperon/wiki/mcp/server/tools/admin_backup"

# Card history and restore
require_relative "../lib/hyperon/wiki/mcp/server/tools/get_card_history"
require_relative "../lib/hyperon/wiki/mcp/server/tools/get_revision"
require_relative "../lib/hyperon/wiki/mcp/server/tools/restore_card"
require_relative "../lib/hyperon/wiki/mcp/server/tools/list_trash"

# Weekly summaries
require_relative "../lib/hyperon/wiki/mcp/server/tools/create_weekly_summary"

# Health check
require_relative "../lib/hyperon/wiki/mcp/server/tools/health_check"

# Phase 3: Advanced operations
require_relative "../lib/hyperon/wiki/mcp/server/tools/batch_cards"
require_relative "../lib/hyperon/wiki/mcp/server/tools/run_query"
require_relative "../lib/hyperon/wiki/mcp/server/tools/spoiler_scan"

# Auto-linking
require_relative "../lib/hyperon/wiki/mcp/server/tools/auto_link"

# File/image upload
require_relative "../lib/hyperon/wiki/mcp/server/tools/upload_file"
require_relative "../lib/hyperon/wiki/mcp/server/tools/upload_from_url"
require_relative "../lib/hyperon/wiki/mcp/server/tools/get_file_url"

# Content editing tools
require_relative "../lib/hyperon/wiki/mcp/server/tools/append_content"
require_relative "../lib/hyperon/wiki/mcp/server/tools/prepend_content"
require_relative "../lib/hyperon/wiki/mcp/server/tools/find_and_replace"
require_relative "../lib/hyperon/wiki/mcp/server/tools/find_in_card"
require_relative "../lib/hyperon/wiki/mcp/server/tools/get_card_outline"
require_relative "../lib/hyperon/wiki/mcp/server/tools/submit_feedback"

# Tier 2/3: Section editing, diffing, stats, templates
require_relative "../lib/hyperon/wiki/mcp/server/tools/update_section"
require_relative "../lib/hyperon/wiki/mcp/server/tools/diff_card"
require_relative "../lib/hyperon/wiki/mcp/server/tools/get_card_stats"
require_relative "../lib/hyperon/wiki/mcp/server/tools/template_card"

# Initialize the Hyperon Wiki tools
# This creates an authenticated client using environment variables:
# - MCP_USERNAME + MCP_PASSWORD (recommended)
# - OR MCP_API_KEY + MCP_ROLE
magi_tools = begin
  Hyperon::Wiki::Mcp::Tools.new
rescue StandardError => e
  $stderr.puts "Error initializing Hyperon Wiki tools: #{e.message}"
  $stderr.puts "Please ensure you have configured authentication in .env or environment variables:"
  $stderr.puts "  MCP_USERNAME=<your-username>"
  $stderr.puts "  MCP_PASSWORD=<your-password>"
  $stderr.puts "OR:"
  $stderr.puts "  MCP_API_KEY=<your-api-key>"
  $stderr.puts "  MCP_ROLE=user|gm|admin"
  exit 1
end

# Get working directory from args or environment
working_directory = ARGV[0] || ENV["MAGI_WORKING_DIR"] || Dir.pwd

# Create server context with our tools instance
server_context = {
  magi_tools: magi_tools,
  working_directory: working_directory
}

# Create the MCP server
server = ::MCP::Server.new(
  name: "hyperon-wiki",
  version: Hyperon::Wiki::Mcp::VERSION,
  tools: [
    # Core card operations
    Hyperon::Wiki::Mcp::Server::Tools::GetCard,
    Hyperon::Wiki::Mcp::Server::Tools::SearchCards,
    Hyperon::Wiki::Mcp::Server::Tools::CreateCard,
    Hyperon::Wiki::Mcp::Server::Tools::UpdateCard,
    Hyperon::Wiki::Mcp::Server::Tools::DeleteCard,
    Hyperon::Wiki::Mcp::Server::Tools::RenameCard,
    Hyperon::Wiki::Mcp::Server::Tools::ListChildren,

    # Tag operations
    Hyperon::Wiki::Mcp::Server::Tools::GetTags,
    Hyperon::Wiki::Mcp::Server::Tools::SearchByTags,
    Hyperon::Wiki::Mcp::Server::Tools::SuggestTags,

    # Relationships
    Hyperon::Wiki::Mcp::Server::Tools::GetRelationships,


    # Types and rendering
    Hyperon::Wiki::Mcp::Server::Tools::GetTypes,
    Hyperon::Wiki::Mcp::Server::Tools::RenderContent,

    # Admin operations
    Hyperon::Wiki::Mcp::Server::Tools::AdminBackup,

    # Card history and restore
    Hyperon::Wiki::Mcp::Server::Tools::GetCardHistory,
    Hyperon::Wiki::Mcp::Server::Tools::GetRevision,
    Hyperon::Wiki::Mcp::Server::Tools::RestoreCard,
    Hyperon::Wiki::Mcp::Server::Tools::ListTrash,

    # Weekly summaries
    Hyperon::Wiki::Mcp::Server::Tools::CreateWeeklySummary,

    # Health check
    Hyperon::Wiki::Mcp::Server::Tools::HealthCheck,

    # Phase 3: Advanced operations
    Hyperon::Wiki::Mcp::Server::Tools::BatchCards,
    Hyperon::Wiki::Mcp::Server::Tools::RunQuery,
    Hyperon::Wiki::Mcp::Server::Tools::SpoilerScan,

    # Auto-linking
    Hyperon::Wiki::Mcp::Server::Tools::AutoLink,

    # File/image upload
    Hyperon::Wiki::Mcp::Server::Tools::UploadFile,
    Hyperon::Wiki::Mcp::Server::Tools::UploadFromUrl,
    Hyperon::Wiki::Mcp::Server::Tools::GetFileUrl,

    # Content editing tools
    Hyperon::Wiki::Mcp::Server::Tools::AppendContent,
    Hyperon::Wiki::Mcp::Server::Tools::PrependContent,
    Hyperon::Wiki::Mcp::Server::Tools::FindAndReplace,
    Hyperon::Wiki::Mcp::Server::Tools::FindInCard,
    Hyperon::Wiki::Mcp::Server::Tools::GetCardOutline,
    Hyperon::Wiki::Mcp::Server::Tools::SubmitFeedback,

    # Tier 2/3: Section editing, diffing, stats, templates
    Hyperon::Wiki::Mcp::Server::Tools::UpdateSection,
    Hyperon::Wiki::Mcp::Server::Tools::DiffCard,
    Hyperon::Wiki::Mcp::Server::Tools::GetCardStats,
    Hyperon::Wiki::Mcp::Server::Tools::TemplateCard
  ],
  server_context: server_context
)

# Require the stdio transport
require "mcp/server/transports/stdio_transport"

# Set up stdio transport
transport = ::MCP::Server::Transports::StdioTransport.new(server)

# Log startup to stderr (stdio is for JSON-RPC communication)
$stderr.puts "Hyperon Wiki MCP Server v#{Hyperon::Wiki::Mcp::VERSION}"
$stderr.puts "Working directory: #{working_directory}"
$stderr.puts "Authenticated as: #{magi_tools.client.config.username || 'API Key'}"
$stderr.puts "Ready for MCP requests via stdio..."

# Start the server
begin
  transport.open
rescue Interrupt
  $stderr.puts "\nShutting down gracefully..."
  exit 0
rescue StandardError => e
  $stderr.puts "Fatal error: #{e.message}"
  $stderr.puts e.backtrace.join("\n")
  exit 1
end
